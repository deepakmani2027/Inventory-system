# Frontend Environment Variables
# Copy this file to .env.local and fill in your actual values from Supabase and your LLM provider

# Backend API URL (IMPORTANT for deployment)
# Local development: http://localhost:8001
# Production: Set to your deployed backend URL (e.g., https://backend.yourdomain.com)
NEXT_PUBLIC_API_URL=http://localhost:8001

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_key_here

# LLM Configuration (OpenRouter)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Email Configuration (Optional - for OTP and notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here
SMTP_FROM="InventoryPro <your_email@gmail.com>"
