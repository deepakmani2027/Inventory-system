{
  "$schema": "https://railway.app/json-schema/railway.json",
  "services": {
    "backend": {
      "startCommand": "cd backend && python server.py",
      "nixpacksPkgs": ["python3", "python3Packages.pip"],
      "root": "backend",
      "buildCommand": "pip install -r requirements.txt"
    }
  },
  "env": {
    "PORT": "8001"
  }
}
